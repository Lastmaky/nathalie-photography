---
---

<footer class="bg-ink text-cream pt-20 pb-10 px-6 md:px-12 lg:px-20">
  <div class="max-w-7xl mx-auto">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row justify-between items-start gap-12 mb-16">
      <!-- Brand -->
      <div class="flex flex-col">
        <span class="font-display text-3xl font-light tracking-widest2 text-cream">NATHALIE</span>
        <span class="font-body text-[10px] tracking-widest3 uppercase text-cream/50 mt-1">Calderón Photography</span>
        <p class="font-body text-sm text-cream/60 mt-5 max-w-xs leading-relaxed">
          Capturando los momentos más valiosos de tu vida con elegancia y dedicación.
        </p>
      </div>

      <!-- Nav links -->
      <div class="flex flex-col gap-3">
        <span class="font-body text-xs tracking-widest2 uppercase text-cream/40 mb-2">Páginas</span>
        <a href="/nathalie-photography/" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Inicio</a>
        <a href="/nathalie-photography/servicios" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Servicios</a>
        <a href="/nathalie-photography/servicios/maternidad" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Maternidad</a>
        <a href="/nathalie-photography/servicios/recien-nacido" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Recién nacido</a>
        <a href="/nathalie-photography/servicios/mini-sesiones" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Mini sesiones</a>
        <a href="/nathalie-photography/servicios/mama-bebe" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Mamá y bebé</a>
        <a href="/nathalie-photography/contacto" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300 link-underline">Contacto</a>
      </div>

      <!-- Contact -->
      <div class="flex flex-col gap-3">
        <span class="font-body text-xs tracking-widest2 uppercase text-cream/40 mb-2">Contacto</span>
        <p class="font-body text-sm text-cream/70">Santiago, Chile</p>
        <a href="mailto:hola@nathaliecalderon.cl" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300">hola@nathaliecalderon.cl</a>
        <a href="https://instagram.com" target="_blank" class="font-body text-sm text-cream/70 hover:text-gold transition-colors duration-300">@nathaliecalderonphoto</a>
        <a
          href="/nathalie-photography/contacto"
          class="mt-4 inline-flex border border-cream/30 px-6 py-2.5 font-body text-xs tracking-widest2 uppercase text-cream hover:bg-cream hover:text-ink transition-all duration-300 w-fit"
        >
          Agendar sesión
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-cream/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-body text-xs text-cream/30">
        © {new Date().getFullYear()} Nathalie Calderón Photography. Todos los derechos reservados.
      </p>
      <p class="font-body text-xs text-cream/20">Diseñado con amor en Santiago</p>
    </div>
  </div>
</footer>
