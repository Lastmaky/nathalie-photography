---

const navLinks = [
  { href: '/nathalie-photography/', label: 'Inicio' },
  { href: '/nathalie-photography/servicios/', label: 'Servicios' },
  { href: '/nathalie-photography/contacto/', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 px-6 md:px-12 lg:px-20"
>
  <div class="flex items-center justify-between py-5">
    <!-- Logo -->
    <a href="/nathalie-photography/" class="group flex flex-col leading-none">
      <span class="font-display text-xl font-light tracking-widest2 text-ink group-hover:text-gold transition-colors duration-300">
        NATHALIE
      </span>
      <span class="font-body text-[10px] tracking-widest3 uppercase text-muted mt-0.5">
        Calderón Photography
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-body text-xs tracking-widest2 uppercase link-underline transition-colors duration-300 ${
            currentPath === link.href ? 'text-gold' : 'text-ink hover:text-gold'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <a
      href="/nathalie-photography//contacto"
      class="hidden md:inline-flex items-center gap-2 border border-ink/30 px-6 py-2.5 font-body text-xs tracking-widest2 uppercase text-ink hover:bg-ink hover:text-cream transition-all duration-300"
    >
      Agendar
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menú">
      <span class="hamburger-line block w-6 h-px bg-ink transition-all duration-300"></span>
      <span class="hamburger-line block w-4 h-px bg-ink transition-all duration-300"></span>
      <span class="hamburger-line block w-6 h-px bg-ink transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-cream flex flex-col items-center justify-center gap-10 -translate-y-full transition-transform duration-500 md:hidden"
>
  {navLinks.map(link => (
    <a
      href={link.href}
      class="font-display text-4xl font-light italic text-ink hover:text-gold transition-colors duration-300"
    >
      {link.label}
    </a>
  ))}
  <a
    href="/contacto"
    class="mt-4 border border-ink/40 px-8 py-3 font-body text-xs tracking-widest2 uppercase text-ink hover:bg-ink hover:text-cream transition-all duration-300"
  >
    Agendar sesión
  </a>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = document.querySelectorAll('.hamburger-line');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('-translate-y-full', !open);
    menu?.classList.toggle('translate-y-0', open);
    lines[0]?.classList.toggle('rotate-45', open);
    lines[0]?.classList.toggle('translate-y-2', open);
    lines[1]?.classList.toggle('opacity-0', open);
    lines[2]?.classList.toggle('-rotate-45', open);
    lines[2]?.classList.toggle('-translate-y-2', open);
  });
</script>
